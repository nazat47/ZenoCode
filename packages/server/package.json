{
  "name": "@zenocode/server",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "postinstall": "bun run --cwd ../database db:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/google": "^4.0.17",
    "@ai-sdk/openai": "^4.0.14",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/bun": "^10.65.0",
    "@sentry/hono": "^10.65.0",
    "@zenocode/database": "workspace:*",
    "@zenocode/shared": "workspace:*",
    "ai": "^7.0.28",
    "dotenv": "^17.4.2",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
