  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.35",
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "@zenocode/shared": "workspace:*",
    "ai": "^7.0.32",
    "date-fns": "^4.4.0",
    "hono": "^4.12.30",
    "open": "^11.0.0",
    "opentui-spinner": "^0.0.7",
    "pretty-ms": "^9.3.0",
    "react": "^19.2.6",
